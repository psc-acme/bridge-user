{
    "name": "psc-acme/bridge-user",
    "description": "Package bridge-user for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\BridgeUser\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "symfony/cache": "^7.0",
        "symfony/mailer": "^7.0",
        "aws/aws-sdk-php": "^3.332"
    },
    "require-dev": {
        "vimeo/psalm": "^5.0",
        "rector/rector": "^1.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}